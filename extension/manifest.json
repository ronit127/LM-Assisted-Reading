{
  "manifest_version": 3,
  "name": "LM-Assisted Reading",
  "version": "0.1.0",
  "description": "Displays page text in the extension popup.",

  "action": {
    "default_popup": "popup.html",
    "default_title": "LM-Assisted Reading",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "permissions": [
    "activeTab",
    "scripting"
  ],

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
