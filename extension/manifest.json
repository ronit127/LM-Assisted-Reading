{
  "manifest_version": 3,
  "name": "LM-Assisted Reading",
  "version": "1.0.0",
  "description": "Inline LM-assisted reading tool.",

  "action": {
    "default_title": "LM-Assisted Reading",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["sidebar.css"]
    }
  ],

  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],

  "host_permissions": [
    "https://bedrock-runtime.us-east-1.amazonaws.com/*",
    "https://bedrock-runtime.us-west-2.amazonaws.com/*",
    "https://bedrock-runtime.eu-west-1.amazonaws.com/*",
    "https://bedrock-runtime.ap-southeast-1.amazonaws.com/*",
    "https://bedrock-runtime.ap-northeast-1.amazonaws.com/*"
  ],

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
